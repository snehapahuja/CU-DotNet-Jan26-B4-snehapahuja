@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5">
    <div class="text-center p-5 rounded shadow-sm bg-light">
        <h1 class="display-4 fw-bold text-primary">Northwind Catalog</h1>
        <p class="lead text-muted">Browse categories and products in a modern dashboard style</p>

        <div class="mt-4">
            <a class="btn btn-primary btn-lg px-4 mx-2" asp-controller="Categories" asp-action="Index">
                Categories
            </a>
            <a class="btn btn-success btn-lg px-4 mx-2" asp-controller="Summary" asp-action="Index">
                Summary
            </a>
        </div>
    </div>
</div>