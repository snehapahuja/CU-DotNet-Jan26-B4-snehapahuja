@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero {
        background: linear-gradient(135deg,#4a90e2 0%,#9013fe 100%);
        color: white;
        padding: 80px 0;
        border-radius: 8px;
    }

        .hero * {
            color: white !important;
        }

        .hero .btn-cta {
            background: #fff;
            color: #4a4a4a !important;
            border-radius: 50px;
            padding: 12px 28px;
            font-weight: 600;
        }

            .hero .btn-cta:hover {
                background: #f1f1f1;
            }

    .features .card {
        background: linear-gradient(135deg,#4a90e2 0%,#9013fe 100%);
        color: white;
        border: none;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0,0,0,.15);
        transition: 0.3s ease;
    }

        .features .card:hover {
            transform: translateY(-5px);
        }

    .card-title {
        font-weight: bold;
    }
</style>

<section class="hero">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-md-7">
                <h1 class="display-4 fw-bold">
                    Discover your next unforgettable trip
                </h1>

                <p class="lead">
                    Handpicked destinations, real traveler ratings and inspiration
                    to help you explore the world.
                </p>

                <p class="opacity-75">
                    Your personal travel companion ✈️
                </p>

                <p>
                    <a asp-controller="Travel" asp-action="Index"
                       class="btn btn-cta btn-lg">
                         Browse Destinations
                    </a>
                </p>
            </div>

            <div class="col-md-5 d-none d-md-block">
                <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470"
                     alt="Travel"
                     class="img-fluid rounded shadow" />
            </div>

        </div>

        <div class="row mt-5 features">

            <div class="col-md-4">
                <div class="card p-3">
                    <div class="card-body">
                        <h5 class="card-title"> Explore</h5>
                        <p class="card-text">
                            Discover curated destinations and hidden gems tailored to your travel style.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3">
                    <div class="card-body">
                        <h5 class="card-title"> Plan</h5>
                        <p class="card-text">
                            Keep notes, ratings and last visited dates for the places you love.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3">
                    <div class="card-body">
                        <h5 class="card-title"> Share</h5>
                        <p class="card-text">
                            Share your favorite destinations with friends and fellow travelers.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>