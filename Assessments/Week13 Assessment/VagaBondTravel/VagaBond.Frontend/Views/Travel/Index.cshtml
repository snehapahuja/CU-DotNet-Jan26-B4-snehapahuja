@model IEnumerable<VagaBond.Frontend.Models.Destination>

<style>
  .destination-card { border: none; border-radius: 12px; overflow: hidden; }
  .destination-card img { height: 180px; object-fit: cover; width: 100%; }
  .badge-visited { position: absolute; top: 12px; right: 12px; background: rgba(255,255,255,0.9); color: #333; }
  .card-overlay { padding: 12px; }
  .rating { color: #f5b301; }
</style>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Destinations</h2>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back Home</a>
  </div>

  <div class="row g-4">
    @foreach (var item in Model)
    {
      <div class="col-sm-6 col-md-4">
        <div class="card destination-card shadow-sm">
          <div class="position-relative">
                        <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e" alt="@item.CityName" />
            <span class="badge badge-visited rounded-pill px-2 py-1">@item.LastVisited.ToString("yyyy-MM-dd")</span>
          </div>
          <div class="card-body card-overlay">
            <h5 class="card-title">@item.CityName, <small class="text-muted">@item.Country</small></h5>
            <p class="mb-2 text-truncate">@item.Description</p>
            <div class="d-flex justify-content-between align-items-center">
              <div class="rating">
                @for (int i = 0; i < 5; i++) {
                    if (i < item.Rating) { <span>&#9733;</span> } else { <span class="text-muted">&#9734;</span> }
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
</div>
