@model IEnumerable<VagaBond.Frontend.Models.Destination>

<style>
    .destination-card {
        border: none;
        border-radius: 14px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .destination-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
        }

    .badge-visited {
        background: #f1f3f5;
        color: #555;
        font-size: 0.75rem;
    }

    .card-overlay {
        padding: 16px;
    }

    .card-title {
        font-weight: 600;
        margin-bottom: 6px;
    }

    .card-description {
        font-size: 0.9rem;
        color: #666;
        min-height: 40px;
    }

    .rating-text {
        font-size: 0.9rem;
        font-weight: 500;
        color: #333;
    }
</style>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Destinations</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back Home</a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-sm-6 col-md-4">
                <div class="card destination-card shadow-sm">

                    <div class="card-body card-overlay">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">
                                @item.CityName,
                                <small class="text-muted">@item.Country</small>
                            </h5>
                            <span class="badge badge-visited rounded-pill px-2 py-1">
                                @item.LastVisited.ToString("yyyy-MM-dd")
                            </span>
                        </div>

                        <p class="card-description text-truncate">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <div class="rating-text">
                                Rating: @item.Rating / 5
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>