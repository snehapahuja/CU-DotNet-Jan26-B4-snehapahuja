@model GlobalMartPr.Models.Cart

@{
    ViewData["Title"] = "Cart";
}

<div class="container py-4">
    <div class="card">
        <div class="card-header">
            <h3 class="mb-0">Your Cart</h3>
        </div>

        <div class="card-body">

            @if (Model.Items == null || !Model.Items.Any())
            {
                <div class="alert alert-info">Your cart is empty.</div>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Price</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td class="text-end">@item.Price.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                var total = Model.Items.Sum(i => i.Price);

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <a class="btn btn-link" asp-controller="Product" asp-action="Index">
                        Continue shopping
                    </a>

                    <div>
                        <span class="fs-5 me-3">
                            Total: <strong>@total.ToString("C")</strong>
                        </span>

                        <a class="btn btn-primary">Checkout</a>
                    </div>
                </div>
            }

        </div>
    </div>
</div>