@{
    ViewData["Title"] = "Training Programs";
}

<div class="container mt-4">
    <h2>Corporate Training Programs</h2>

    <div class="accordion" id="trainingAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#t1">
                    Leadership Training
                </button>
            </h2>
            <div id="t1" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Develop leadership skills for managers and executives.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#t2">
                    Technical Skills
                </button>
            </h2>
            <div id="t2" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Training programs for IT and technical teams.
                </div>
            </div>
        </div>

    </div>
</div>