@{
    ViewData["Title"] = "Consulting Services";
}

<div class="container mt-4">
    <h2>Consulting Services</h2>

    <div class="accordion" id="consultingAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#one">
                    Business Strategy
                </button>
            </h2>
            <div id="one" class="accordion-collapse collapse ">
                <div class="accordion-body">
                    We help organizations build strong long-term business strategies.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#two">
                    Market Research
                </button>
            </h2>
            <div id="two" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Detailed market insights and competitor analysis.
                </div>
            </div>
        </div>

    </div>
</div>