@model IEnumerable<NorthwindCatalog.Services.DTOs.CategorySummaryDto>

<div class="container py-4">

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">No summary data available.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-primary">
                    <tr>
                        <th>Category</th>
                        <th>Product Count</th>
                        <th>Avg Price</th>
                        <th>Most Expensive</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.CategoryName</td>
                            <td>@item.ProductCount</td>
                            <td>@item.AvgPrice.ToString("C")</td>
                            <td class="text-success fw-bold">@item.MostExpensiveProduct</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>